#!/usr/bin/env bash
# OhMyStack setup — build browser binary + register skills with OpenCode
set -e
umask 077  # Restrict new files to owner-only (0o600 files, 0o700 dirs)

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  echo "Install with checksum verification:" >&2
  echo '  BUN_VERSION="1.3.10"' >&2
  echo '  tmpfile=$(mktemp)' >&2
  echo '  curl -fsSL "https://bun.sh/install" -o "$tmpfile"' >&2
  echo '  echo "Verify checksum before running: shasum -a 256 $tmpfile"' >&2
  echo '  BUN_VERSION="$BUN_VERSION" bash "$tmpfile" && rm "$tmpfile"' >&2
  exit 1
fi

SOURCE_OHMYSTACK_DIR="$(cd "$(dirname "$0")" && pwd -P)"
BROWSE_BIN="$SOURCE_OHMYSTACK_DIR/browse/dist/browse"
DESIGN_BIN="$SOURCE_OHMYSTACK_DIR/design/dist/design"
OPENCODE_SKILLS_SOURCE="$SOURCE_OHMYSTACK_DIR/opencode/skills"
OHMYSTACK_STATE_DIR="$HOME/.ohmystack"

# Shared brand constants and legacy generated skill prefixes.
source "$SOURCE_OHMYSTACK_DIR/scripts/brand-map.sh"

IS_WINDOWS=0
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT) IS_WINDOWS=1 ;;
esac

# ─── Quiet mode helper ────────────────────────────────────────
QUIET=0
log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

reset_path() {
  local target="$1"
  if [ -L "$target" ]; then
    rm -f "$target"
  elif [ -d "$target" ]; then
    rm -rf "$target"
  elif [ -e "$target" ]; then
    rm -f "$target"
  fi
}

link_path() {
  local source_path="$1"
  local target_path="$2"
  reset_path "$target_path"
  ln -snf "$source_path" "$target_path"
}

install_generated_opencode_skills() {
  local generated_skills_dir="$1"
  local install_root="$2"
  local root_skill_dir="$generated_skills_dir/$OLD_BRAND"

  if [ ! -d "$generated_skills_dir" ]; then
    echo "OhMyStack setup failed: generated OpenCode skills are missing at $generated_skills_dir" >&2
    exit 1
  fi

  if [ ! -f "$root_skill_dir/SKILL.md" ]; then
    echo "OhMyStack setup failed: root OpenCode skill is missing at $root_skill_dir/SKILL.md" >&2
    exit 1
  fi

  mkdir -p "$install_root"
  link_path "$root_skill_dir/SKILL.md" "$install_root/SKILL.md"

  for skill_dir in "$generated_skills_dir"/"${OLD_BRAND}"*/; do
    [ -d "$skill_dir" ] || continue
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "$OLD_BRAND" ] && continue
    link_path "$skill_dir" "$install_root/$skill_name"
  done
}

install_opencode_runtime_root() {
  local install_root="$1"

  if [ -L "$install_root" ]; then
    rm -f "$install_root"
  elif [ -e "$install_root" ] && [ ! -d "$install_root" ]; then
    echo "OhMyStack setup failed: install target is not a directory: $install_root" >&2
    exit 1
  fi

  mkdir -p "$install_root" "$install_root/browse" "$install_root/design" "$install_root/review"

  install_generated_opencode_skills "$OPENCODE_SKILLS_SOURCE" "$install_root"
  link_path "$SOURCE_OHMYSTACK_DIR/bin" "$install_root/bin"
  link_path "$SOURCE_OHMYSTACK_DIR/ETHOS.md" "$install_root/ETHOS.md"
  link_path "$SOURCE_OHMYSTACK_DIR/browse/dist" "$install_root/browse/dist"
  link_path "$SOURCE_OHMYSTACK_DIR/browse/bin" "$install_root/browse/bin"
  link_path "$SOURCE_OHMYSTACK_DIR/design/dist" "$install_root/design/dist"

  for review_file in checklist.md design-checklist.md greptile-triage.md TODOS-format.md; do
    if [ -f "$SOURCE_OHMYSTACK_DIR/review/$review_file" ]; then
      link_path "$SOURCE_OHMYSTACK_DIR/review/$review_file" "$install_root/review/$review_file"
    fi
  done
}

# ─── Parse flags ──────────────────────────────────────────────
HOST="opencode"
LOCAL_INSTALL=0
TEAM_MODE=0
NO_TEAM_MODE=0
while [ $# -gt 0 ]; do
  case "$1" in
    --host) [ -z "$2" ] && echo "Missing value for --host (expected opencode or auto)" >&2 && exit 1; HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    --local) LOCAL_INSTALL=1; shift ;;
    --prefix|--no-prefix) shift ;;
    --team) TEAM_MODE=1; shift ;;
    --no-team) NO_TEAM_MODE=1; shift ;;
    -q|--quiet) QUIET=1; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  auto|opencode) HOST="opencode" ;;
  *) echo "Unknown --host value: $HOST (expected opencode or auto)" >&2; exit 1 ;;
esac

if [ "$LOCAL_INSTALL" -eq 1 ]; then
  INSTALL_ROOT="$(pwd)/.opencode/skills/$NEW_BRAND"
else
  INSTALL_ROOT="$HOME/.config/opencode/skills/$NEW_BRAND"
fi

# 1. Build browse and design binaries if needed.
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ] || [ ! -x "$DESIGN_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_OHMYSTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$SOURCE_OHMYSTACK_DIR/design/src" -type f -newer "$DESIGN_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$SOURCE_OHMYSTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -f "$SOURCE_OHMYSTACK_DIR/bun.lock" ] && [ "$SOURCE_OHMYSTACK_DIR/bun.lock" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  log "Building OhMyStack binaries..."
  (
    cd "$SOURCE_OHMYSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run build
  )
  if [ ! -f "$SOURCE_OHMYSTACK_DIR/browse/dist/.version" ]; then
    git -C "$SOURCE_OHMYSTACK_DIR" rev-parse HEAD > "$SOURCE_OHMYSTACK_DIR/browse/dist/.version" 2>/dev/null || true
  fi
  if [ ! -f "$SOURCE_OHMYSTACK_DIR/design/dist/.version" ]; then
    git -C "$SOURCE_OHMYSTACK_DIR" rev-parse HEAD > "$SOURCE_OHMYSTACK_DIR/design/dist/.version" 2>/dev/null || true
  fi
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "OhMyStack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

if [ ! -x "$DESIGN_BIN" ]; then
  echo "OhMyStack setup failed: design binary missing at $DESIGN_BIN" >&2
  exit 1
fi

# 1b. Generate OpenCode skill docs when binaries are already fresh.
if [ "$NEEDS_BUILD" -eq 0 ]; then
  log "Generating OpenCode skill docs..."
  (
    cd "$SOURCE_OHMYSTACK_DIR"
    bun install --frozen-lockfile 2>/dev/null || bun install
    bun run gen:skill-docs --host opencode
  )
fi

ensure_playwright_browser() {
  if [ "$IS_WINDOWS" -eq 1 ]; then
    (
      cd "$SOURCE_OHMYSTACK_DIR"
      node -e "const { chromium } = require('playwright'); (async () => { const b = await chromium.launch(); await b.close(); })()" 2>/dev/null
    )
  else
    (
      cd "$SOURCE_OHMYSTACK_DIR"
      bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
    ) >/dev/null 2>&1
  fi
}

# 2. Ensure Playwright's Chromium is available.
if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "$SOURCE_OHMYSTACK_DIR"
    bunx playwright install chromium
  )

  if [ "$IS_WINDOWS" -eq 1 ]; then
    if ! command -v node >/dev/null 2>&1; then
      echo "OhMyStack setup failed: Node.js is required on Windows (Bun cannot launch Chromium due to a pipe bug)" >&2
      echo "  Install Node.js: https://nodejs.org/" >&2
      exit 1
    fi
    echo "Windows detected — verifying Node.js can load Playwright..."
    (
      cd "$SOURCE_OHMYSTACK_DIR"
      node -e "require('playwright')" 2>/dev/null || npm install --no-save playwright
    )
  fi
fi

if ! ensure_playwright_browser; then
  if [ "$IS_WINDOWS" -eq 1 ]; then
    echo "OhMyStack setup failed: Playwright Chromium could not be launched via Node.js" >&2
    echo "  This is a known issue with Bun on Windows (oven-sh/bun#4253)." >&2
    echo "  Ensure Node.js is installed and can load Playwright successfully." >&2
  else
    echo "OhMyStack setup failed: Playwright Chromium could not be launched" >&2
  fi
  exit 1
fi

# 3. Ensure ~/.ohmystack global state directory exists.
mkdir -p "$OHMYSTACK_STATE_DIR/projects"

# 4. Install for OpenCode only.
install_opencode_runtime_root "$INSTALL_ROOT"

log "OhMyStack ready (OpenCode)."
log "  install: $INSTALL_ROOT"
log "  browse: $BROWSE_BIN"
log "  docs: https://github.com/sigvardt/OhMyStack"

# 5. First-time welcome.
if [ ! -f "$OHMYSTACK_STATE_DIR/.welcome-seen" ]; then
  log "  Welcome to OhMyStack. OpenCode skills are now linked and ready."
  touch "$OHMYSTACK_STATE_DIR/.welcome-seen"
fi
rm -f /tmp/ohmystack-latest-version

# DEPRECATED: Team mode not supported in OhMyStack
if [ "$TEAM_MODE" -eq 1 ] || [ "$NO_TEAM_MODE" -eq 1 ]; then
  log ""
  log "Team mode is deprecated and skipped in OhMyStack."
  log "  Use the shared OpenCode install at $HOME/.config/opencode/skills/$NEW_BRAND"
  log "  See: https://github.com/sigvardt/OhMyStack"
fi
