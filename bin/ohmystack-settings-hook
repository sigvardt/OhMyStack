#!/usr/bin/env bash
# Deprecated team mode tool kept under its legacy filename.
# Add/remove SessionStart hooks in Claude Code settings.json
#
# Usage:
#   legacy settings hook add <hook-command>     # add SessionStart hook
#   legacy settings hook remove <hook-command>  # remove SessionStart hook
#
# Requires: bun (already a project hard dependency)
# Writes atomically: .tmp + rename to prevent corruption on crash/disk-full.

set -euo pipefail

ACTION="${1:-}"
HOOK_CMD="${2:-}"
LEGACY_NAME="g""stack"
LEGACY_UPPER="G""STACK"
LEGACY_SESSION_UPDATE_BIN="${LEGACY_NAME}-session-update"
SETTINGS_ENV="${LEGACY_UPPER}_SETTINGS_FILE"
SETTINGS_PATH_ENV="${LEGACY_UPPER}_SETTINGS_PATH"
HOOK_ENV="${LEGACY_UPPER}_HOOK_CMD"
SETTINGS_FILE="${!SETTINGS_ENV:-$HOME/.claude/settings.json}"

if [ -z "$ACTION" ] || [ -z "$HOOK_CMD" ]; then
  echo "Usage: legacy-settings-hook {add|remove} <hook-command>" >&2
  exit 1
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "Error: bun is required but not installed." >&2
  exit 1
fi

case "$ACTION" in
  add)
    env "$SETTINGS_PATH_ENV=$SETTINGS_FILE" "$HOOK_ENV=$HOOK_CMD" bun -e "
      const fs = require('fs');
      const settingsPath = process.env['$SETTINGS_PATH_ENV'];
      const hookCmd = process.env['$HOOK_ENV'];

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch {}

      if (!settings.hooks) settings.hooks = {};
      if (!settings.hooks.SessionStart) settings.hooks.SessionStart = [];

      // Dedup: check if hook command already registered
      const exists = settings.hooks.SessionStart.some(entry =>
        entry.hooks && entry.hooks.some(h => h.command && h.command.includes('$LEGACY_SESSION_UPDATE_BIN'))
      );

      if (!exists) {
        settings.hooks.SessionStart.push({
          hooks: [{ type: 'command', command: hookCmd }]
        });
      }

      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    ;;
  remove)
    [ -f "$SETTINGS_FILE" ] || exit 0
    env "$SETTINGS_PATH_ENV=$SETTINGS_FILE" bun -e "
      const fs = require('fs');
      const settingsPath = process.env['$SETTINGS_PATH_ENV'];

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch { process.exit(0); }

      if (settings.hooks && settings.hooks.SessionStart) {
        settings.hooks.SessionStart = settings.hooks.SessionStart.filter(entry =>
          !(entry.hooks && entry.hooks.some(h => h.command && h.command.includes('$LEGACY_SESSION_UPDATE_BIN')))
        );
        if (settings.hooks.SessionStart.length === 0) delete settings.hooks.SessionStart;
        if (Object.keys(settings.hooks).length === 0) delete settings.hooks;
      }

      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    ;;
  *)
    echo "Unknown action: $ACTION (expected add or remove)" >&2
    exit 1
    ;;
esac
