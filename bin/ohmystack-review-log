#!/usr/bin/env bash
# ohmystack-review-log — atomically log a review result
# Usage: ohmystack-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/ohmystack-slug" 2>/dev/null)"
OHMYSTACK_HOME="${OHMYSTACK_HOME:-$HOME/.ohmystack}"
mkdir -p "$OHMYSTACK_HOME/projects/$SLUG"

# Validate: input must be parseable JSON (reject malformed or injection attempts)
INPUT="$1"
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  # Not valid JSON — refuse to append
  echo "ohmystack-review-log: invalid JSON, skipping" >&2
  exit 1
fi

echo "$INPUT" >> "$OHMYSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
