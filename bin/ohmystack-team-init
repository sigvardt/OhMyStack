#!/usr/bin/env bash
# Deprecated team mode tool kept under its legacy filename.
# Generate repo-level bootstrap files for legacy team mode
#
# Usage:
#   legacy-team-init optional   # gentle CLAUDE.md suggestion, one-time offer
#   legacy-team-init required   # CLAUDE.md enforcement + PreToolUse hook
#
# Run from the root of your team's repo (not from the legacy install directory).

set -euo pipefail

MODE="${1:-}"
LEGACY_NAME="g""stack"
LEGACY_UPPER="G""STACK"
LEGACY_SKILLS_REL=".claude/skills/$LEGACY_NAME"
LEGACY_HOME_SKILLS="$HOME/.claude/skills/$LEGACY_NAME"
LEGACY_REPO_URL="https://github.com/garrytan/g""stack"
LEGACY_GIT_URL="${LEGACY_REPO_URL}.git"
LEGACY_OK="${LEGACY_UPPER}_OK"
LEGACY_MISSING="${LEGACY_UPPER}_MISSING"
LEGACY_CHECK_HOOK="check-${LEGACY_NAME}.sh"
LEGACY_SETTINGS_PATH_ENV="${LEGACY_UPPER}_SETTINGS_PATH"

if [ "$MODE" != "optional" ] && [ "$MODE" != "required" ]; then
  echo "Usage: legacy-team-init {optional|required}" >&2
  echo "" >&2
  echo "  optional  — suggest the legacy install once per developer (gentle)" >&2
  echo "  required  — enforce the legacy install, block work without it" >&2
  exit 1
fi

# Must be in a git repo
if ! git rev-parse --show-toplevel >/dev/null 2>&1; then
  echo "Error: not in a git repository. Run from your project root." >&2
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
CLAUDE_MD="$REPO_ROOT/CLAUDE.md"
GENERATED=()

# ── Migrate vendored copy if present ──────────────────────────

if [ -d "$REPO_ROOT/$LEGACY_SKILLS_REL" ] && [ ! -L "$REPO_ROOT/$LEGACY_SKILLS_REL" ]; then
  if [ -f "$REPO_ROOT/$LEGACY_SKILLS_REL/VERSION" ] || [ -d "$REPO_ROOT/$LEGACY_SKILLS_REL/.git" ]; then
    echo "  Found vendored $LEGACY_NAME copy at $REPO_ROOT/$LEGACY_SKILLS_REL"
    echo "  Team mode uses the global install — removing vendored copy..."
    ( cd "$REPO_ROOT" && git rm -r --cached "$LEGACY_SKILLS_REL/" 2>/dev/null ) || true
    if [ -f "$REPO_ROOT/.gitignore" ]; then
      if ! grep -qF "$LEGACY_SKILLS_REL/" "$REPO_ROOT/.gitignore" 2>/dev/null; then
        echo "$LEGACY_SKILLS_REL/" >> "$REPO_ROOT/.gitignore"
      fi
    else
      echo "$LEGACY_SKILLS_REL/" > "$REPO_ROOT/.gitignore"
    fi
    rm -rf "$REPO_ROOT/$LEGACY_SKILLS_REL"
    GENERATED+=(".gitignore")
    echo "  Removed vendored copy and added $LEGACY_SKILLS_REL/ to .gitignore"
  fi
fi

# ── CLAUDE.md snippet ──────────────────────────────────────────

if [ "$MODE" = "optional" ]; then
  SNIPPET=$(cat <<EOF
## ${LEGACY_NAME} (recommended)

This project uses [${LEGACY_NAME}](${LEGACY_REPO_URL}) for AI-assisted workflows.
Install it for the best experience:

```bash
git clone --depth 1 ${LEGACY_GIT_URL} ${LEGACY_HOME_SKILLS}
cd ${LEGACY_HOME_SKILLS} && ./setup --team
```

Skills like /qa, /ship, /review, /investigate, and /browse become available after install.
Use /browse for all web browsing. Use ${LEGACY_HOME_SKILLS}/... for legacy file paths.
EOF
)
else
  SNIPPET=$(cat <<EOF
## ${LEGACY_NAME} (REQUIRED — global install)

**Before doing ANY work, verify ${LEGACY_NAME} is installed:**

```bash
test -d ${LEGACY_HOME_SKILLS}/bin && echo "${LEGACY_OK}" || echo "${LEGACY_MISSING}"
```

If ${LEGACY_MISSING}: STOP. Do not proceed. Tell the user:

> ${LEGACY_NAME} is required for all AI-assisted work in this repo.
> Install it:
> ```bash
> git clone --depth 1 ${LEGACY_GIT_URL} ${LEGACY_HOME_SKILLS}
> cd ${LEGACY_HOME_SKILLS} && ./setup --team
> ```
> Then restart your AI coding tool.

Do not skip skills, ignore ${LEGACY_NAME} errors, or work around a missing install.

Using these legacy skills: after install, skills like /qa, /ship, /review, /investigate,
and /browse are available. Use /browse for all web browsing.
Use ${LEGACY_HOME_SKILLS}/... for legacy file paths (the global path).
EOF
)
fi

# Check if CLAUDE.md already has a legacy section
if [ -f "$CLAUDE_MD" ] && grep -q "## $LEGACY_NAME" "$CLAUDE_MD" 2>/dev/null; then
  echo "CLAUDE.md already has a legacy section. Skipping CLAUDE.md update."
  echo "  To replace it, remove the existing ## $LEGACY_NAME section and re-run."
else
  if [ -f "$CLAUDE_MD" ]; then
    echo "" >> "$CLAUDE_MD"
  fi
  echo "$SNIPPET" >> "$CLAUDE_MD"
  GENERATED+=("CLAUDE.md")
  echo "  + CLAUDE.md — added $LEGACY_NAME $MODE section"
fi

# ── Required mode: enforcement hook ────────────────────────────

if [ "$MODE" = "required" ]; then
  HOOKS_DIR="$REPO_ROOT/.claude/hooks"
  SETTINGS="$REPO_ROOT/.claude/settings.json"

  # Create enforcement hook script
  mkdir -p "$HOOKS_DIR"
  cat > "$HOOKS_DIR/$LEGACY_CHECK_HOOK" <<HOOK_EOF
#!/bin/bash
# Block skill usage when the legacy install is not available globally.

if [ ! -d "$LEGACY_HOME_SKILLS/bin" ]; then
  cat >&2 <<'MSG'
BLOCKED: ${LEGACY_NAME} is not installed globally.

${LEGACY_NAME} is required for AI-assisted work in this repo.

Install it:
  git clone --depth 1 ${LEGACY_GIT_URL} ${LEGACY_HOME_SKILLS}
  cd ${LEGACY_HOME_SKILLS} && ./setup --team

Then restart your AI coding tool.
MSG
  echo '{"permissionDecision":"deny","message":"legacy install required but missing. See stderr for install instructions."}'
  exit 0
fi

echo '{}'
HOOK_EOF
  chmod +x "$HOOKS_DIR/$LEGACY_CHECK_HOOK"
  GENERATED+=(".claude/hooks/$LEGACY_CHECK_HOOK")
  echo "  + .claude/hooks/$LEGACY_CHECK_HOOK — enforcement hook"

  # Add hook to project-level settings.json
  if command -v bun >/dev/null 2>&1; then
    env "$LEGACY_SETTINGS_PATH_ENV=$SETTINGS" bun -e "
      const fs = require('fs');
      const settingsPath = process.env['$LEGACY_SETTINGS_PATH_ENV'];

      let settings = {};
      try { settings = JSON.parse(fs.readFileSync(settingsPath, 'utf8')); } catch {}

      if (!settings.hooks) settings.hooks = {};
      if (!settings.hooks.PreToolUse) settings.hooks.PreToolUse = [];

      // Dedup
      const exists = settings.hooks.PreToolUse.some(entry =>
        entry.matcher === 'Skill' &&
        entry.hooks && entry.hooks.some(h => h.command && h.command.includes('$LEGACY_CHECK_HOOK'))
      );

      if (!exists) {
        settings.hooks.PreToolUse.push({
          matcher: 'Skill',
          hooks: [{
            type: 'command',
            command: '\"\$CLAUDE_PROJECT_DIR/.claude/hooks/$LEGACY_CHECK_HOOK\"'
          }]
        });
      }

      const tmp = settingsPath + '.tmp';
      fs.writeFileSync(tmp, JSON.stringify(settings, null, 2) + '\n');
      fs.renameSync(tmp, settingsPath);
    " 2>/dev/null
    GENERATED+=(".claude/settings.json")
    echo "  + .claude/settings.json — PreToolUse hook registered"
  else
    echo "  ! bun not found — manually add the PreToolUse hook to .claude/settings.json"
  fi
fi

# ── Summary ────────────────────────────────────────────────────

echo ""
echo "Team mode ($MODE) initialized."
echo ""
if [ ${#GENERATED[@]} -gt 0 ]; then
  echo "Commit the generated files:"
  echo "  git add ${GENERATED[*]}"
  echo "  git commit -m \"chore: require legacy team install for AI-assisted work\""
fi
echo ""
echo "Each developer then runs:"
echo "  git clone --depth 1 ${LEGACY_GIT_URL} ${LEGACY_HOME_SKILLS}"
echo "  cd ${LEGACY_HOME_SKILLS} && ./setup --team"
