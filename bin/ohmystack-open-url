#!/usr/bin/env bash
# ohmystack-open-url — cross-platform URL opener
#
# Usage: ohmystack-open-url <url>
set -euo pipefail

URL="${1:?Usage: ohmystack-open-url <url>}"

case "$(uname -s)" in
  Darwin)  open "$URL" ;;
  Linux)   xdg-open "$URL" 2>/dev/null || echo "$URL" ;;
  MINGW*|MSYS*|CYGWIN*) start "$URL" ;;
  *)       echo "$URL" ;;
esac
