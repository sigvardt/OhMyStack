#!/usr/bin/env bash
# ohmystack-review-read — read review log and config for dashboard
# Usage: ohmystack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/ohmystack-slug" 2>/dev/null)"
OHMYSTACK_HOME="${OHMYSTACK_HOME:-$HOME/.ohmystack}"
cat "$OHMYSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/ohmystack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
